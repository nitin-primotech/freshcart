# Copy from Firebase Console → Project settings → Web app
# Use the SAME project as delivrn_merchant (foodrush-1c40b)

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional — only if using a non-default Firestore database
# EXPO_PUBLIC_FIREBASE_DATABASE_ID=(default)

# Google Sign-In (Firebase Console → Authentication → Google → Web client ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS OAuth client ID from GoogleService-Info.plist (CLIENT_ID)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Reversed iOS client ID from GoogleService-Info.plist (REVERSED_CLIENT_ID)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
