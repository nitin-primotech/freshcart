{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "useExhaustiveDependencies": "warn",
        "noUndeclaredVariables": "error",
        "noConstAssign": "error",
        "noInvalidUseBeforeDeclaration": "error"
      },
      "suspicious": {
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noExplicitAny": "off",
        "noConsole": "off",
        "noVar": "error"
      },
      "style": {
        "useConst": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!.expo",
      "!dist",
      "!build",
      "!android",
      "!ios",
      "!expo-env.d.ts",
      "!.claude",
      "!bun.lock",
      "!package-lock.json",
      "!**/*.svg"
    ]
  }
}
